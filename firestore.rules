rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rankings/{rankingId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'level',
          'gold',
          'clearTimeMs',
          'spentGold',
          'enhanceAttempts',
          'time',
          'createdAt'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.matches('^[A-Za-z]{1,10}$') &&
        request.resource.data.level == 30 &&
        request.resource.data.gold is number &&
        request.resource.data.gold >= 0 &&
        request.resource.data.clearTimeMs is number &&
        request.resource.data.clearTimeMs >= 0 &&
        request.resource.data.spentGold is number &&
        request.resource.data.spentGold >= 0 &&
        request.resource.data.enhanceAttempts is number &&
        request.resource.data.enhanceAttempts >= 0 &&
        request.resource.data.time is number &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /developerMessages/{messageId} {
      allow read, update, delete: if false;

      allow create: if
        request.resource.data.keys().hasOnly([
          'message',
          'level',
          'best',
          'gold',
          'monsterLevel',
          'userId',
          'email',
          'page',
          'time',
          'createdAt'
        ]) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 1 &&
        request.resource.data.message.size() <= 300 &&
        request.resource.data.level is number &&
        request.resource.data.level >= 0 &&
        request.resource.data.level <= 30 &&
        request.resource.data.best is number &&
        request.resource.data.best >= 0 &&
        request.resource.data.best <= 30 &&
        request.resource.data.gold is number &&
        request.resource.data.gold >= 0 &&
        request.resource.data.monsterLevel is number &&
        request.resource.data.monsterLevel >= 1 &&
        request.resource.data.monsterLevel <= 20 &&
        request.resource.data.userId is string &&
        request.resource.data.userId.size() <= 128 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 160 &&
        request.resource.data.page is string &&
        request.resource.data.page.size() <= 300 &&
        request.resource.data.time is number &&
        request.resource.data.createdAt == request.time;
    }
  }
}
